{
  "manifest_version": 3,
  "name": "Stampmark",
  "version": "0.1.0",
  "description": "Captura cualquier parte del navegador con forma de estampa, cópiala al portapapeles y guárdala en un moodboard infinito.",
  "permissions": ["activeTab", "scripting", "storage", "unlimitedStorage", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stampmark"
  },
  "web_accessible_resources": [
    {
      "resources": ["stamp.svg", "selector.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
